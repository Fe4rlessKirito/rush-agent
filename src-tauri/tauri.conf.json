{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rush",
  "version": "1.0.4",
  "identifier": "com.rush.agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Rush",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../local-proxy/README.txt",
      "../local-proxy/requirements.txt",
      "../local-proxy/start-rush.bat",
      "../local-proxy/start.bat",
      "../local-proxy/backend/*.py",
      "../local-proxy/worker/*.py"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwRTBFRkE4NTZGOTA0M0QKUldROUJQbFdxTy9na0FuWkxEVXFydVY5dllqRmFwUndLMDBZeFVvRFRUNGhtTVA5VCtiWXNWYlkK",
      "endpoints": [
        "https://github.com/Fe4rlessKirito/rush-agent/releases/latest/download/latest.json"
      ]
    }
  }
}
